# Database
DATABASE_URL=postgresql+asyncpg://hotel_user:hotel_pass@localhost:5432/hotel_chatbot

# LLM (vLLM lokal)
LLM_BASE_URL=http://localhost:8000
MODEL_NAME=hotel-llm
EMBEDDING_MODEL=intfloat/multilingual-e5-base
LLM_ENABLE_THINKING=false

# HMS Integration
USE_MOCK_HMS=true
HMS_BASE_URL=http://localhost:9000
HMS_API_KEY=dummy-key

# WAHA (WhatsApp)
WAHA_URL=http://localhost:3000
WAHA_API_KEY=dummy-waha-key

# Notification
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=dummy@gmail.com
SMTP_PASSWORD=dummy-password
NOTIFICATION_EMAIL=sales@hotel.com

# App
SECRET_KEY=change-this-in-production-min-32-chars
DEBUG=true
APP_PORT=8001

# Portal Admin
PORTAL_PASSWORD=admin123
JWT_EXPIRE_HOURS=24

# Redis & Embedder (Large Scale Architecture)
REDIS_URL=redis://localhost:6379/0
USE_MOCK_EMBEDDER=true